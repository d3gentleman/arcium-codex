# Keystatic / GitHub Storage
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# GitHub repo Keystatic writes to
NEXT_PUBLIC_GITHUB_OWNER=
NEXT_PUBLIC_GITHUB_REPO=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Neon / Postgres
ARCIUMCODEX_DATABASE_URL=
ARCIUMCODEX_DATABASE_URL_UNPOOLED=

# Comma-separated verified emails permitted to access /keystatic
ADMIN_EMAILS=

# Mailpit
MAILPIT_HOST=127.0.0.1
MAILPIT_PORT=1025
MAILPIT_FROM=no-reply@learnarcium.local

# 'local' for development, 'github' for production
KEYSTATIC_STORAGE_MODE=local
