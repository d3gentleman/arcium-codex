# Keystatic / GitHub Storage
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# GitHub repo Keystatic writes to
NEXT_PUBLIC_GITHUB_OWNER=
NEXT_PUBLIC_GITHUB_REPO=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Auth.js
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Comma-separated GitHub usernames permitted to access /admin
ADMIN_GITHUB_USERNAMES=

# 'local' for development, 'github' for production
KEYSTATIC_STORAGE_MODE=local
